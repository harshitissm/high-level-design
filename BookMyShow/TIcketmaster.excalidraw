      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1721375321234,
      "link": null,
      "locked": false,
      "fontSize": 20,
      "fontFamily": 1,
      "text": "Functional Requirement\n- Book tickets\n- View an event\n- Search for events\n\nNon-functional Requirements\n- low latency search \n- strong consistency for booking tickets & high availability for search and viewing events\n- read >> write\n- scalability to handle surges from popular events\n\n---------\n\nOut of scope:\n- GDPR compliance\n- fault tolerance \n- etc.  \n",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirement\n- Book tickets\n- View an event\n- Search for events\n\nNon-functional Requirements\n- low latency search \n- strong consistency for booking tickets & high availability for search and viewing events\n- read >> write\n- scalability to handle surges from popular events\n\n---------\n\nOut of scope:\n- GDPR compliance\n- fault tolerance \n- etc.  \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
